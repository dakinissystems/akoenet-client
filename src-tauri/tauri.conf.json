{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AkoeNet",
  "version": "1.5.12",
  "identifier": "com.dakinis.akoenet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AkoeNet",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Dakinis Systems",
    "copyright": "Dakinis Systems",
    "shortDescription": "AkoeNet",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "akoenet"
        ]
      }
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://akoenet.dakinissystems.com/releases/desktop/latest.json"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}
